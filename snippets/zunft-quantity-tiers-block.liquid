{% comment %}
  Zunft-Anstecker Quantity Tiers — quantity-setter variant.
  Three pills set the cart-form's quantity input. Add-to-cart is handled by the
  existing main "In den Warenkorb legen" button. Discounts apply via Shopify
  native automatic discount rules at checkout.
{% endcomment %}

{%- liquid
  assign target_handle = block.settings.product_handle | default: 'zunft-anstecker'
  assign is_target = false
  if product != blank and product.handle == target_handle
    assign is_target = true
  endif
-%}

{%- if is_target -%}
  <link rel="stylesheet" href="{{ 'zunft-tiers.css' | asset_url }}" media="print" onload="this.media='all'">
  <noscript>{{ 'zunft-tiers.css' | asset_url | stylesheet_tag }}</noscript>

  <div
    class="zunft-tiers zunft-tiers--quantity"
    data-zunft-tiers
    data-product-id="{{ product.id }}"
    data-product-handle="{{ product.handle }}"
    aria-labelledby="ZunftTiersBlock-Heading-{{ block.id }}"
    {{ block.shopify_attributes }}
  >
    {%- if block.settings.heading != blank -%}
      <p id="ZunftTiersBlock-Heading-{{ block.id }}" class="zunft-tiers__label">
        {{ block.settings.heading | escape }}
      </p>
    {%- endif -%}

    <div class="zunft-tiers__pills" role="group" aria-label="{{ block.settings.heading | default: 'Mengenrabatt' | escape }}">
      {%- for i in (1..3) -%}
        {%- liquid
          assign qty_key = 'tier' | append: i | append: '_qty'
          assign label_key = 'tier' | append: i | append: '_label'
          assign discount_key = 'tier' | append: i | append: '_discount'
          assign qty = block.settings[qty_key]
          assign label = block.settings[label_key]
          assign discount = block.settings[discount_key]
        -%}
        <button type="button"
          class="zunft-tiers__pill"
          data-zunft-tier-button
          data-tier-qty="{{ qty }}"
          data-tier-discount="{{ discount }}"
          aria-pressed="false">
          <span class="zunft-tiers__pill-qty">{{ qty }}</span>
          <span class="zunft-tiers__pill-text">
            {%- if qty == 1 -%}Anstecker{%- else -%}Anstecker{%- endif -%}
          </span>
          {%- if discount > 0 -%}
            <span class="zunft-tiers__pill-discount">−{{ discount }}%</span>
          {%- endif -%}
        </button>
      {%- endfor -%}
    </div>

    <p class="zunft-tiers__status" data-zunft-tiers-status role="status" aria-live="polite" hidden></p>

    {%- if block.settings.hint != blank -%}
      <p class="zunft-tiers__hint">{{ block.settings.hint | escape }}</p>
    {%- endif -%}
  </div>

  <script src="{{ 'zunft-tiers.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
